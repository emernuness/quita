{
	"name": "quita",
	"private": true,
	"packageManager": "pnpm@10.25.0",
	"scripts": {
		"dev": "turbo run dev --filter=!@quita/mobile",
		"build": "turbo run build --filter=!@quita/mobile",
		"typecheck": "turbo run typecheck --filter=!@quita/mobile",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"clean": "turbo run clean",
		"test": "turbo run test --filter=!@quita/mobile",
		"db:generate": "turbo run db:generate --filter=@quita/api",
		"db:push": "turbo run db:push --filter=@quita/api",
		"db:migrate": "turbo run db:migrate --filter=@quita/api",
		"db:seed": "turbo run db:seed --filter=@quita/api",
		"db:studio": "turbo run db:studio --filter=@quita/api"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@nestjs/core",
			"@prisma/client",
			"@prisma/engines",
			"prisma"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"turbo": "^2.4.4",
		"typescript": "^5.7.3"
	}
}
