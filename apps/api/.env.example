# =============================================================================
# QUITA API — variaveis de ambiente
# =============================================================================

# Banco
DATABASE_URL="postgresql://quita:quita@localhost:5432/quita?schema=public"

# Redis (BullMQ + cache)
REDIS_URL="redis://localhost:6379"

# API
PORT=3000
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Auth (ADR-0001 + ADR-0002)
# -----------------------------------------------------------------------------
# - JWT_SECRET: assina access tokens JWT (HS256). Min 32 chars em prod.
# - REFRESH_TOKEN_HMAC_SECRET: HMAC-SHA256 que hashea refresh tokens em DB.
#   NUNCA reutilizar JWT_SECRET. Min 32 chars em prod.
JWT_SECRET="change-me-in-production-min-32-chars-required-strict"
REFRESH_TOKEN_HMAC_SECRET="change-me-in-production-distinct-from-jwt-secret"

# CORS (lista separada por virgula). Vazio em dev cai em fallback localhost.
CORS_ORIGINS=""

# -----------------------------------------------------------------------------
# Observabilidade (no-op se ausente)
# -----------------------------------------------------------------------------
# Sentry
SENTRY_DSN=""
RELEASE_SHA=""

# PostHog (server)
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# -----------------------------------------------------------------------------
# Email transacional (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM="Quita <noreply@quita.com.br>"

# -----------------------------------------------------------------------------
# Pagamentos (Stripe Connect BR)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# OCR (OpenAI Vision)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=""

# -----------------------------------------------------------------------------
# Storage (Cloudflare R2 — S3-compatible, zero egress fee)
# -----------------------------------------------------------------------------
# R2_ACCOUNT_ID: encontrado em Cloudflare Dashboard > R2 > Manage R2 API tokens
# R2_BUCKET: nome do bucket (default: quita-ocr-uploads)
# R2_PUBLIC_URL: https://pub-<id>.r2.dev OU dominio custom configurado
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="quita-ocr-uploads"
R2_PUBLIC_URL=""
