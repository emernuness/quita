# Banco
DATABASE_URL="postgresql://quita:quita@localhost:5432/quita?schema=public"

# Redis (BullMQ + cache — usados a partir da Onda 1)
REDIS_URL="redis://localhost:6379"

# API
PORT=3000
NODE_ENV="development"

# Auth (Onda 1 / ADR-0001 e 0002)
# - JWT_SECRET: assina access tokens JWT (HS256). Min 32 chars em prod.
# - REFRESH_TOKEN_HMAC_SECRET: chave HMAC-SHA256 que hashea refresh tokens
#   antes de persistir. NUNCA reutilizar JWT_SECRET.
JWT_SECRET="change-me-in-production-min-32-chars"
REFRESH_TOKEN_HMAC_SECRET="change-me-in-production-distinct-from-jwt-secret"

# CORS (lista separada por virgula) ou "*" para qualquer origem.
# Em dev, deixe vazio (fallback inclui localhost:4400 e localhost:3000).
CORS_ORIGINS=""
