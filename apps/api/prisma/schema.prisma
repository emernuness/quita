generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum PlanType {
  free
  premium
}

enum FinancialType {
  fixed
  one_time
  recurring
}

enum ExpenseCategory {
  housing
  bills // legacy alias for utilities (mantido por compat)
  utilities // luz, agua, gas
  telecom // internet, celular, TV
  food // mercado, refeicoes essenciais
  transport // combustivel, transporte publico
  health // plano de saude, medicamentos continuos
  education // mensalidade, material
  childcare // creche, baba
  work_tools // ferramentas/equipamentos para trabalhar
  insurance // seguros essenciais
  legal // pensao, multa, taxa judicial
  subscription // assinaturas nao essenciais
  leisure // lazer, restaurante
  other
}

enum IncomeSource {
  salary
  extra
  help
  other
}

enum DebtNature {
  installment
  recurring
  one_time
}

enum DebtStatus {
  on_time
  overdue
  renegotiated
  paid
}

enum PaymentType {
  full
  partial
  renegotiated
}

enum PlanStrategy {
  smallest_first
  highest_interest
  custom
  snowball
  avalanche
  hybrid
  crisis
}

enum InsightType {
  tip
  action
  warning
  negotiation
  expense_cut
}

enum ExportFormat {
  pdf
  csv
}

enum ExportStatus {
  processing
  ready
  expired
}

enum TimelineItemStatus {
  pending
  completed
  skipped
}

// --- Enums novos da Fase 2 v2 ---

enum FinancialState {
  healthy_with_debt
  tight_budget
  monthly_deficit
  overindebtedness
  practical_insolvency
}

enum OperationMode {
  payoff
  stabilization
  crisis_mode
  protection
  survival
}

enum ConsequenceType {
  service_cut
  loss_of_asset
  legal_action
  fine
  none
}

enum CollateralType {
  none
  vehicle
  property
  salary
  other
}

enum InterestClass {
  high
  medium
  low
  unknown
}

enum RiskClass {
  critical
  high
  medium
  low
}

enum ConfidenceLevel {
  high
  medium
  low
}

enum ActionType {
  pay
  negotiate
  pause
  cut
  wait
  review
  refuse
  monitor
}

enum TargetType {
  debt
  expense
  income
  general
}

enum ActionStatus {
  pending
  completed
  skipped
  dismissed
  expired
}

enum SettlementRecommendation {
  accept
  negotiate_lower
  reject
}

enum PreferredStrategy {
  snowball
  avalanche
  hybrid
  undecided
}

enum MainConcern {
  collection_pressure
  service_cut_risk
  disorganization
  shame
  where_to_start
}

enum RegionType {
  capital
  metro
  interior
}

enum SupportChannelType {
  procon
  defensoria
  federal_gov
  bank_mediation
  ngo
  serasa
  other
}

enum SupportChannelScope {
  federal
  state
  municipal
}

// --- Enums novos da Fase 2 v2 (6 novos) ---

enum ExpenseFrequency {
  monthly
  bimonthly
  quarterly
  semiannual
  annual
  irregular
}

enum IncomeStability {
  stable
  variable
  seasonal
}

enum DiagnosisLevel {
  minimal
  basic
  detailed
}

enum GoalType {
  debt_freedom
  house
  education
  family
  travel
  peace
  security
  retirement
  other
}

enum RateSource {
  user_provided
  market_reference
  unknown
}

enum ConsentType {
  terms_of_use
  privacy_policy
  data_processing
  marketing_communications
}

// --- Enums novos do Fase 2 v2.1 patch (IncomeFrequency) ---

enum IncomeFrequency {
  recurring
  installment
  one_time
  irregular
}

// --- Enums novos para auth (Onda 1 / ADR-0001 e 0002) ---

enum AuthEventType {
  login_success
  login_failure
  logout
  logout_all
  refresh_success
  refresh_reuse_detected
  password_changed
  password_reset_requested
  password_reset_completed
}

// ============================================================================
// Models existentes (estendidos)
// ============================================================================

model User {
  id                       String           @id @default(uuid())
  name                     String           @db.VarChar(255)
  email                    String           @unique @db.VarChar(255)
  phone                    String           @db.VarChar(20)
  passwordHash             String           @map("password_hash") @db.VarChar(255)
  avatarInitials           String?          @map("avatar_initials") @db.VarChar(5)
  googleId                 String?          @map("google_id") @db.VarChar(255)
  stripeCustomerId         String?          @unique @map("stripe_customer_id") @db.VarChar(255)
  biometricFingerprint     Boolean?         @default(false) @map("biometric_fingerprint")
  biometricFace            Boolean?         @default(false) @map("biometric_face")
  discreteMode             Boolean?         @default(false) @map("discrete_mode")
  onboardingStep           Int?             @default(0) @map("onboarding_step") @db.SmallInt
  onboardingCompleted      Boolean?         @default(false) @map("onboarding_completed")
  planType                 PlanType         @default(free) @map("plan_type")
  planExpiresAt            DateTime?        @map("plan_expires_at")
  lastSyncAt               DateTime?        @map("last_sync_at")
  // --- Novos campos Fase 2 v2 ---
  dependentsCount          Int?             @default(0) @map("dependents_count") @db.SmallInt
  city                     String?          @db.VarChar(100)
  stateCode                String?          @map("state_code") @db.VarChar(2)
  cityIbgeCode             String?          @map("city_ibge_code") @db.VarChar(7)
  lastFinancialState       FinancialState?  @map("last_financial_state")
  lastOperationMode        OperationMode?   @map("last_operation_mode")
  lastDecisionAt           DateTime?        @map("last_decision_at")
  overallIncomeStability   IncomeStability? @map("overall_income_stability")
  diagnosisLevel           DiagnosisLevel   @default(minimal) @map("diagnosis_level")
  onboardingCompletedSteps Json?            @map("onboarding_completed_steps")
  nextReviewDate           DateTime?        @map("next_review_date") @db.Date
  acceptedTermsAt          DateTime?        @map("accepted_terms_at")
  acceptedTermsVersion     String?          @map("accepted_terms_version") @db.VarChar(20)
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")
  // Soft delete LGPD: marca conta como excluida; hard delete acontece
  // apos 30 dias via DataRetentionCleanupProcessor (Fase 3 §16).
  deletedAt                DateTime?        @map("deleted_at")

  incomes                 Income[]
  expenses                Expense[]
  debts                   Debt[]
  payments                Payment[]
  paymentPlans            PaymentPlan[]
  insights                AiInsight[]
  notificationPrefs       NotificationPreference?
  journeyStats            UserJourneyStats?
  exports                 DataExport[]
  // --- Novas relacoes ---
  behaviorProfile         BehaviorProfile?
  monthlyActionPlans      MonthlyActionPlan[]
  settlementEvaluations   SettlementEvaluation[]
  financialStateSnapshots FinancialStateSnapshot[]
  emergencyReserve        EmergencyReserve?
  goals                   UserGoal[]
  consentLogs             ConsentLog[]
  refreshTokens           RefreshToken[]
  authAuditLogs           AuthAuditLog[]

  @@index([nextReviewDate])
  @@index([deletedAt])
  @@map("users")
}

model Income {
  id                String           @id @default(uuid())
  userId            String           @map("user_id")
  name              String           @db.VarChar(255)
  amount            Decimal          @db.Decimal(12, 2)
  type              FinancialType
  // Novo enum (Fase 2 v2.1) — coexiste com type ate refactor completo
  frequency         IncomeFrequency? @default(recurring)
  dueDate           DateTime?        @map("due_date") @db.Date
  installments      Int?             @db.SmallInt
  installmentAmount Decimal?         @map("installment_amount") @db.Decimal(12, 2)
  sourceCategory    IncomeSource?    @map("source_category")
  isActive          Boolean          @default(true) @map("is_active")
  // --- Novos campos Fase 2 v2 ---
  paymentDay        Int?             @map("payment_day") @db.SmallInt
  confidenceLevel   ConfidenceLevel? @map("confidence_level")
  historyMonths     Int?             @map("history_months") @db.SmallInt
  guaranteedAmount  Decimal?         @map("guaranteed_amount") @db.Decimal(12, 2)
  upperBoundAmount  Decimal?         @map("upper_bound_amount") @db.Decimal(12, 2)
  stabilityType     IncomeStability  @default(stable) @map("stability_type")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("incomes")
}

model Expense {
  id                  String           @id @default(uuid())
  userId              String           @map("user_id")
  name                String           @db.VarChar(255)
  amount              Decimal          @db.Decimal(12, 2)
  type                FinancialType
  category            ExpenseCategory
  dueDate             DateTime?        @map("due_date") @db.Date
  installments        Int?             @db.SmallInt
  installmentAmount   Decimal?         @map("installment_amount") @db.Decimal(12, 2)
  isActive            Boolean          @default(true) @map("is_active")
  // --- Novos campos Fase 2 v2 ---
  isEssential         Boolean          @default(false) @map("is_essential")
  isIncomeRelated     Boolean          @default(false) @map("is_income_related")
  isLegalObligation   Boolean          @default(false) @map("is_legal_obligation")
  canReduce           Boolean          @default(false) @map("can_reduce")
  canCancel           Boolean          @default(false) @map("can_cancel")
  consequenceIfUnpaid ConsequenceType? @map("consequence_if_unpaid")
  frequency           ExpenseFrequency @default(monthly)
  monthlyProvision    Decimal?         @map("monthly_provision") @db.Decimal(12, 2)
  nextOccurrence      DateTime?        @map("next_occurrence") @db.Date
  provisionStartedAt  DateTime?        @map("provision_started_at") @db.Date
  dataConfidence      ConfidenceLevel  @default(medium) @map("data_confidence")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendedActions RecommendedAction[]

  @@index([userId, isActive])
  @@index([userId, isEssential])
  @@index([frequency, nextOccurrence])
  @@map("expenses")
}

model DebtCategory {
  id                     String    @id @default(uuid())
  slug                   String    @unique @db.VarChar(50)
  name                   String    @db.VarChar(100)
  icon                   String    @db.VarChar(50)
  // --- Novos campos Fase 2 v2 ---
  defaultRiskClass       RiskClass @default(medium) @map("default_risk_class")
  affectsSurvivalDefault Boolean   @default(false) @map("affects_survival_default")
  affectsIncomeDefault   Boolean   @default(false) @map("affects_income_default")
  hasLegalRiskDefault    Boolean   @default(false) @map("has_legal_risk_default")
  description            String?   @db.VarChar(500)
  displayOrder           Int       @default(100) @map("display_order") @db.SmallInt
  createdAt              DateTime  @default(now()) @map("created_at")

  debts Debt[]

  @@map("debt_categories")
}

model Debt {
  id                          String          @id @default(uuid())
  userId                      String          @map("user_id")
  categoryId                  String          @map("category_id")
  creditor                    String          @db.VarChar(255)
  totalAmount                 Decimal         @map("total_amount") @db.Decimal(12, 2)
  nature                      DebtNature      @default(one_time)
  monthlyAmount               Decimal?        @map("monthly_amount") @db.Decimal(12, 2)
  amountPaid                  Decimal         @default(0) @map("amount_paid") @db.Decimal(12, 2)
  hasInterest                 Boolean?        @default(false) @map("has_interest")
  dueDate                     DateTime?       @map("due_date") @db.Date
  status                      DebtStatus      @default(on_time)
  overdueMonths               Int?            @map("overdue_months") @db.SmallInt
  daysOverdue                 Int             @default(0) @map("days_overdue")
  totalInstallments           Int?            @map("total_installments") @db.SmallInt
  currentInstallment          Int?            @map("current_installment") @db.SmallInt
  installmentsPaid            Int?            @map("installments_paid") @db.SmallInt
  installmentsOverdue         Int?            @default(0) @map("installments_overdue") @db.SmallInt
  priorityOrder               Int?            @map("priority_order") @db.SmallInt
  paidAt                      DateTime?       @map("paid_at")
  interestSaved               Decimal?        @map("interest_saved") @db.Decimal(12, 2)
  // --- Novos campos Fase 2 v2 ---
  affectsSurvival             Boolean         @default(false) @map("affects_survival")
  affectsIncome               Boolean         @default(false) @map("affects_income")
  hasLegalRisk                Boolean         @default(false) @map("has_legal_risk")
  hasCollateral               Boolean         @default(false) @map("has_collateral")
  collateralType              CollateralType? @map("collateral_type")
  isNegotiable                Boolean         @default(true) @map("is_negotiable")
  interestRateMonthly         Decimal?        @map("interest_rate_monthly") @db.Decimal(7, 4)
  interestRateAnnual          Decimal?        @map("interest_rate_annual") @db.Decimal(7, 4)
  interestClass               InterestClass   @default(unknown) @map("interest_class")
  settlementCashAmount        Decimal?        @map("settlement_cash_amount") @db.Decimal(12, 2)
  settlementInstallments      Int?            @map("settlement_installments") @db.SmallInt
  settlementInstallmentAmount Decimal?        @map("settlement_installment_amount") @db.Decimal(12, 2)
  settlementDeadline          DateTime?       @map("settlement_deadline") @db.Date
  stressLevel                 Int?            @map("stress_level") @db.SmallInt
  priorityScore               Decimal?        @map("priority_score") @db.Decimal(7, 2)
  priorityReason              String?         @map("priority_reason") @db.VarChar(500)
  interestRateSource          RateSource      @default(unknown) @map("interest_rate_source")
  lastVerifiedAt              DateTime?       @map("last_verified_at")
  dataConfidence              ConfidenceLevel @default(medium) @map("data_confidence")
  createdAt                   DateTime        @default(now()) @map("created_at")
  updatedAt                   DateTime        @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category              DebtCategory           @relation(fields: [categoryId], references: [id])
  payments              Payment[]
  insights              AiInsight[]
  timelineItems         PlanTimelineItem[]
  recommendedActions    RecommendedAction[]
  settlementEvaluations SettlementEvaluation[]

  @@index([userId, status])
  @@index([userId, priorityScore(sort: Desc)])
  @@map("debts")
}

model Payment {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  debtId       String      @map("debt_id")
  amount       Decimal     @db.Decimal(12, 2)
  paymentType  PaymentType @map("payment_type")
  receiptUrl   String?     @map("receipt_url") @db.VarChar(500)
  canUndoUntil DateTime?   @map("can_undo_until")
  undone       Boolean     @default(false)
  paidAt       DateTime    @map("paid_at")
  createdAt    DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@map("payments")
}

model PaymentPlan {
  id                       String          @id @default(uuid())
  userId                   String          @map("user_id")
  strategy                 PlanStrategy    @default(smallest_first)
  monthlyAvailable         Decimal         @map("monthly_available") @db.Decimal(12, 2)
  totalDebtsCount          Int             @map("total_debts_count") @db.SmallInt
  paidDebtsCount           Int             @default(0) @map("paid_debts_count") @db.SmallInt
  progressPercent          Decimal         @default(0) @map("progress_percent") @db.Decimal(5, 2)
  isCritical               Boolean         @default(false) @map("is_critical")
  allPaid                  Boolean         @default(false) @map("all_paid")
  isActive                 Boolean         @default(true) @map("is_active")
  generatedAt              DateTime        @map("generated_at")
  // --- Novos campos Fase 2 v2 ---
  lastFinancialState       FinancialState? @map("last_financial_state")
  safeCapacity             Decimal?        @map("safe_capacity") @db.Decimal(12, 2)
  simulationConservative   Json?           @map("simulation_conservative")
  simulationOptimized      Json?           @map("simulation_optimized")
  simulationAccelerated    Json?           @map("simulation_accelerated")
  estimatedPayoffMonthsMin Int?            @map("estimated_payoff_months_min") @db.SmallInt
  estimatedPayoffMonthsMax Int?            @map("estimated_payoff_months_max") @db.SmallInt
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  timelineItems PlanTimelineItem[]

  @@index([userId])
  @@map("payment_plans")
}

model PlanTimelineItem {
  id              String             @id @default(uuid())
  planId          String             @map("plan_id")
  debtId          String             @map("debt_id")
  order           Int                @db.SmallInt
  suggestedAmount Decimal            @map("suggested_amount") @db.Decimal(12, 2)
  suggestedDate   DateTime           @map("suggested_date") @db.Date
  status          TimelineItemStatus @default(pending)
  createdAt       DateTime           @default(now()) @map("created_at")

  plan PaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  debt Debt        @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@map("plan_timeline_items")
}

model AiInsight {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  debtId        String?     @map("debt_id")
  type          InsightType
  title         String?     @db.VarChar(255)
  content       String
  actionLabel   String?     @map("action_label") @db.VarChar(100)
  actionUrl     String?     @map("action_url") @db.VarChar(500)
  impactLabel   String?     @map("impact_label") @db.VarChar(50)
  savingsAmount Decimal?    @map("savings_amount") @db.Decimal(12, 2)
  isRead        Boolean     @default(false) @map("is_read")
  createdAt     DateTime    @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt Debt? @relation(fields: [debtId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@map("ai_insights")
}

model NotificationPreference {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  dueDates         Boolean  @default(false) @map("due_dates")
  weeklyProgress   Boolean  @default(true) @map("weekly_progress")
  paymentIncentive Boolean  @default(true) @map("payment_incentive")
  riskAlert        Boolean  @default(true) @map("risk_alert")
  newsAndTips      Boolean  @default(true) @map("news_and_tips")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model DataExport {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  format      ExportFormat
  status      ExportStatus @default(processing)
  fileUrl     String?      @map("file_url") @db.VarChar(500)
  requestedAt DateTime     @default(now()) @map("requested_at")
  readyAt     DateTime?    @map("ready_at")
  expiresAt   DateTime?    @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("data_exports")
}

model UserJourneyStats {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  totalDebtsCleared  Int      @default(0) @map("total_debts_cleared") @db.SmallInt
  journeyMonths      Int      @default(0) @map("journey_months") @db.SmallInt
  totalInterestSaved Decimal  @default(0) @map("total_interest_saved") @db.Decimal(12, 2)
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_journey_stats")
}

// ============================================================================
// Models novos (Fase 2 v2 / v2.1)
// ============================================================================

model BehaviorProfile {
  id                String            @id @default(uuid())
  userId            String            @unique @map("user_id")
  preferredStrategy PreferredStrategy @default(undecided) @map("preferred_strategy")
  mainConcern       MainConcern?      @map("main_concern")
  motivationLevel   Int?              @map("motivation_level") @db.SmallInt
  disciplineLevel   Int?              @map("discipline_level") @db.SmallInt
  preferencesExtra  Json?             @map("preferences_extra")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("behavior_profiles")
}

model MonthlyActionPlan {
  id                           String         @id @default(uuid())
  userId                       String         @map("user_id")
  referenceMonth               DateTime       @map("reference_month") @db.Date
  financialState               FinancialState @map("financial_state")
  operationMode                OperationMode  @map("operation_mode")
  incomeNetMonthly             Decimal        @map("income_net_monthly") @db.Decimal(12, 2)
  essentialsTotal              Decimal        @map("essentials_total") @db.Decimal(12, 2)
  seasonalProvisionTotal       Decimal        @default(0) @map("seasonal_provision_total") @db.Decimal(12, 2)
  incomeProtectiveTotal        Decimal        @map("income_protective_total") @db.Decimal(12, 2)
  legalsTotal                  Decimal        @map("legals_total") @db.Decimal(12, 2)
  minimumVital                 Decimal        @map("minimum_vital") @db.Decimal(12, 2)
  emergencyReserveContribution Decimal        @default(0) @map("emergency_reserve_contribution") @db.Decimal(12, 2)
  safeCapacity                 Decimal        @map("safe_capacity") @db.Decimal(12, 2)
  mainGoal                     String         @map("main_goal") @db.VarChar(500)
  warnings                     Json?
  nextReviewDate               DateTime?      @map("next_review_date") @db.Date
  isActive                     Boolean        @default(true) @map("is_active")
  generatedAt                  DateTime       @default(now()) @map("generated_at")
  createdAt                    DateTime       @default(now()) @map("created_at")
  updatedAt                    DateTime       @updatedAt @map("updated_at")

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  actions RecommendedAction[]

  @@unique([userId, referenceMonth])
  @@index([userId, isActive])
  @@map("monthly_action_plans")
}

model RecommendedAction {
  id                       String          @id @default(uuid())
  planId                   String          @map("plan_id")
  order                    Int             @db.SmallInt
  actionType               ActionType      @map("action_type")
  targetType               TargetType      @map("target_type")
  targetDebtId             String?         @map("target_debt_id")
  targetExpenseId          String?         @map("target_expense_id")
  targetLabel              String          @map("target_label") @db.VarChar(255)
  amount                   Decimal?        @db.Decimal(12, 2)
  maxAffordableInstallment Decimal?        @map("max_affordable_installment") @db.Decimal(12, 2)
  reason                   String          @db.VarChar(500)
  dueDate                  DateTime?       @map("due_date") @db.Date
  dataConfidence           ConfidenceLevel @default(medium) @map("data_confidence")
  status                   ActionStatus    @default(pending)
  completedAt              DateTime?       @map("completed_at")
  dismissedReason          String?         @map("dismissed_reason") @db.VarChar(255)
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  plan          MonthlyActionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  targetDebt    Debt?             @relation(fields: [targetDebtId], references: [id], onDelete: SetNull)
  targetExpense Expense?          @relation(fields: [targetExpenseId], references: [id], onDelete: SetNull)

  @@index([planId, status])
  @@index([targetDebtId])
  @@map("recommended_actions")
}

model SettlementEvaluation {
  id                         String                   @id @default(uuid())
  userId                     String                   @map("user_id")
  debtId                     String                   @map("debt_id")
  proposalCashAmount         Decimal?                 @map("proposal_cash_amount") @db.Decimal(12, 2)
  proposalInstallments       Int?                     @map("proposal_installments") @db.SmallInt
  proposalInstallmentAmount  Decimal?                 @map("proposal_installment_amount") @db.Decimal(12, 2)
  proposalDeadline           DateTime?                @map("proposal_deadline") @db.Date
  recommendation             SettlementRecommendation
  maxSafeInstallment         Decimal?                 @map("max_safe_installment") @db.Decimal(12, 2)
  discountPercent            Decimal?                 @map("discount_percent") @db.Decimal(5, 2)
  wouldCauseNegativeCashflow Boolean                  @default(false) @map("would_cause_negative_cashflow")
  reasoning                  String                   @db.VarChar(1000)
  capacityAtEvaluation       Decimal                  @map("capacity_at_evaluation") @db.Decimal(12, 2)
  evaluatedAt                DateTime                 @default(now()) @map("evaluated_at")
  // Bridge OCR Premium §8: metadados de extracao automatica via OpenAI Vision.
  usedOcr                    Boolean                  @default(false) @map("used_ocr")
  ocrImageUrl                String?                  @map("ocr_image_url") @db.VarChar(500)
  ocrExtractedData           Json?                    @map("ocr_extracted_data")
  ocrConfidence              ConfidenceLevel?         @map("ocr_confidence")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([userId, evaluatedAt])
  @@index([debtId])
  @@map("settlement_evaluations")
}

model FinancialStateSnapshot {
  id               String         @id @default(uuid())
  userId           String         @map("user_id")
  state            FinancialState
  mode             OperationMode
  incomeNetMonthly Decimal        @map("income_net_monthly") @db.Decimal(12, 2)
  essentialsTotal  Decimal        @map("essentials_total") @db.Decimal(12, 2)
  debtsTotal       Decimal        @map("debts_total") @db.Decimal(12, 2)
  safeCapacity     Decimal        @map("safe_capacity") @db.Decimal(12, 2)
  triggerEvent     String?        @map("trigger_event") @db.VarChar(50)
  capturedAt       DateTime       @default(now()) @map("captured_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, capturedAt])
  @@map("financial_state_snapshots")
}

model RegionalMinimumVital {
  id               String     @id @default(uuid())
  stateCode        String     @map("state_code") @db.VarChar(2)
  regionType       RegionType @map("region_type")
  baseAmountSingle Decimal    @map("base_amount_single") @db.Decimal(12, 2)
  basePerDependent Decimal    @map("base_per_dependent") @db.Decimal(12, 2)
  effectiveDate    DateTime   @map("effective_date") @db.Date
  source           String     @db.VarChar(50)
  sourceUrl        String?    @map("source_url") @db.VarChar(500)
  createdAt        DateTime   @default(now()) @map("created_at")

  @@unique([stateCode, regionType, effectiveDate])
  @@map("regional_minimum_vital")
}

model InterestRateReference {
  id                String   @id @default(uuid())
  debtCategorySlug  String   @map("debt_category_slug") @db.VarChar(50)
  monthlyRateMin    Decimal  @map("monthly_rate_min") @db.Decimal(7, 4)
  monthlyRateMax    Decimal  @map("monthly_rate_max") @db.Decimal(7, 4)
  monthlyRateMedian Decimal  @map("monthly_rate_median") @db.Decimal(7, 4)
  effectiveDate     DateTime @map("effective_date") @db.Date
  source            String   @db.VarChar(100)
  sourceSeriesCode  String?  @map("source_series_code") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([debtCategorySlug, effectiveDate])
  @@map("interest_rate_references")
}

model SupportChannel {
  id             String              @id @default(uuid())
  slug           String              @unique @db.VarChar(100)
  name           String              @db.VarChar(255)
  channelType    SupportChannelType  @map("channel_type")
  scope          SupportChannelScope
  stateCode      String?             @map("state_code") @db.VarChar(2)
  cityIbgeCode   String?             @map("city_ibge_code") @db.VarChar(7)
  phone          String?             @db.VarChar(30)
  url            String?             @db.VarChar(500)
  description    String?             @db.VarChar(1000)
  worksForStates Json?               @map("works_for_states")
  isActive       Boolean             @default(true) @map("is_active")
  displayOrder   Int                 @default(100) @map("display_order") @db.SmallInt
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([scope, stateCode, isActive])
  @@map("support_channels")
}

model EmergencyReserve {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  currentAmount Decimal   @default(0) @map("current_amount") @db.Decimal(12, 2)
  targetAmount  Decimal?  @map("target_amount") @db.Decimal(12, 2)
  monthlyTarget Decimal?  @map("monthly_target") @db.Decimal(12, 2)
  isActive      Boolean   @default(false) @map("is_active")
  startedAt     DateTime? @map("started_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("emergency_reserves")
}

model UserGoal {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  goalType      GoalType  @map("goal_type")
  description   String    @db.VarChar(500)
  targetAmount  Decimal?  @map("target_amount") @db.Decimal(12, 2)
  targetDate    DateTime? @map("target_date") @db.Date
  priorityOrder Int       @default(100) @map("priority_order") @db.SmallInt
  isActive      Boolean   @default(true) @map("is_active")
  achievedAt    DateTime? @map("achieved_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("user_goals")
}

model ConsentLog {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  consentType ConsentType @map("consent_type")
  version     String      @db.VarChar(20)
  accepted    Boolean     @default(true)
  acceptedAt  DateTime    @default(now()) @map("accepted_at")
  ipAddress   String?     @map("ip_address") @db.VarChar(45)
  userAgent   String?     @map("user_agent") @db.VarChar(500)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@map("consent_logs")
}

model ScoringWeight {
  id            String   @id @default(uuid())
  factorKey     String   @unique @map("factor_key") @db.VarChar(50)
  weight        Decimal  @db.Decimal(6, 2)
  isPositive    Boolean  @default(true) @map("is_positive")
  effectiveDate DateTime @map("effective_date") @db.Date
  description   String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("scoring_weights")
}

// ============================================================================
// Auth tables (ADR-0001, ADR-0002, LGPD audit)
// ============================================================================

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  tokenHash    String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id")
  createdIp    String?   @map("created_ip") @db.VarChar(45)
  userAgent    String?   @map("user_agent") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("refresh_tokens")
}

model AuthAuditLog {
  id        String        @id @default(uuid())
  userId    String?       @map("user_id")
  email     String?       @db.VarChar(255)
  eventType AuthEventType @map("event_type")
  ipAddress String?       @map("ip_address") @db.VarChar(45)
  userAgent String?       @map("user_agent") @db.VarChar(500)
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([eventType, createdAt])
  @@map("auth_audit_logs")
}
