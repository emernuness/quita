# --- API (apps/api) ---

# Database
DATABASE_URL=postgresql://quita:quita_dev@localhost:5432/quita_dev

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6379

# Auth — obrigatorios em prod com min 32 chars
JWT_SECRET=dev-jwt-secret-replace-in-production-min-32-chars-long
REFRESH_TOKEN_HMAC_SECRET=dev-refresh-secret-replace-in-production-min-32-chars-long

# Ambiente
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3000

# --- Servicos externos (opcionais em dev) ---

# Stripe (se STRIPE_SECRET_KEY presente, STRIPE_WEBHOOK_SECRET tambem obrigatorio)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx

# Cloudflare R2 (se R2_* presente, TODAS 3 obrigatorias)
# R2_ACCOUNT_ID=xxx
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx
# R2_BUCKET=quita-ocr-uploads
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# OpenAI (OCR)
# OPENAI_API_KEY=sk-xxx

# Email transacional
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=noreply@quita.com.br

# Observability
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# POSTHOG_API_KEY=phc_xxx
# POSTHOG_HOST=https://app.posthog.com

# Admin Bull Board (opcional)
# ADMIN_EMAILS=admin@quita.com.br,ops@quita.com.br

# --- Web (apps/web) — variaveis NEXT_PUBLIC_* expostas ao client ---

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry (cliente)
# NEXT_PUBLIC_SENTRY_DSN=

# PostHog (cliente)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
